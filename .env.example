# ── Auth (Privy) ──────────────────────────────────────────────────────────────
VITE_PRIVY_APP_ID=

# ── Serverless function — server-side only, never exposed to browser ──────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WALLET_ID=
PRIVY_WALLET_ADDRESS=

# ── MPP server — required for /api/chat to accept payments from users ─────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MPP_SECRET_KEY=

# ── Anthropic (direct API key — server side only, never exposed to browser) ────
ANTHROPIC_API_KEY=

# ── Upstash Redis — persists MPP channel state across Vercel cold starts ───────
# Create free instance at https://upstash.com → Redis → copy REST URL + token
# Leave blank to use in-memory store (channel lost on cold start → users see 402)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
